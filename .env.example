# Cerefox Environment Configuration
# Copy this file to .env and fill in your values.
# All variables use the CEREFOX_ prefix.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for the application (ingestion, search via supabase-py)
CEREFOX_SUPABASE_URL=https://your-project-ref.supabase.co
CEREFOX_SUPABASE_KEY=your-service-role-key-here

# Required for schema deployment scripts (psycopg2 direct connection)
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Find this in: Supabase Dashboard → Project Settings → Database → Connection string
CEREFOX_DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Embeddings ────────────────────────────────────────────────────────────────
# Which embedder to use: "mpnet" (default, local) or "ollama"
CEREFOX_EMBEDDER=mpnet

# Ollama settings (only needed if CEREFOX_EMBEDDER=ollama)
CEREFOX_OLLAMA_URL=http://localhost:11434
CEREFOX_OLLAMA_MODEL=nomic-embed-text

# ── Chunking ──────────────────────────────────────────────────────────────────
CEREFOX_MAX_CHUNK_CHARS=4000
CEREFOX_MIN_CHUNK_CHARS=100
CEREFOX_OVERLAP_CHARS=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Maximum bytes returned in a single search response (Supabase MCP limit: 65000)
CEREFOX_MAX_RESPONSE_BYTES=65000

# ── Storage ───────────────────────────────────────────────────────────────────
CEREFOX_BACKUP_DIR=./backups

# ── Logging ───────────────────────────────────────────────────────────────────
CEREFOX_LOG_LEVEL=INFO
